        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# PROBLEM 1 — 1D, x yönü, Malzeme A\n",
        "\n",
        "print(\"=\" * 50)\n",
        "print(\"PROBLEM 1 — Tek Malzeme (A), x yönü\")\n",
        "print(\"=\" * 50)\n",
        "\n",
        "# ─── Parametreler ────────────────────\n",
        "kA    = 50.0       # W/m·K  Malzeme A termal iletkenlik\n",
        "L     = 0.1        # m      uzunluk\n",
        "N     = 21         # nod sayısı\n",
        "dx    = L / (N-1)\n",
        "\n",
        "# Konveksiyon (x=0 sol, x=L sağ)\n",
        "h     = 100.0      # W/m²·K\n",
        "T_inf = 300.0      # K\n",
        "\n",
        "# Radyasyon (üst/alt → 1D'de sınır nodlarına eklenir)\n",
        "eps   = 0.85\n",
        "sigma = 5.67e-8    # W/m²·K⁴\n",
        "T_rad = 800.0      # K  radyasyon çevre sıcaklığı\n",
        "\n",
        "T = np.linspace(T_inf, T_rad, N)\n",
        "\n",
        "# ─── İterasyon ─────\n",
        "max_iter = 10000\n",
        "tol      = 1e-6\n",
        "\n",
        "for iteration in range(max_iter):\n",
        "    T_old = T.copy()\n",
        "\n",
        "    A_mat = np.zeros((N, N))\n",
        "    b     = np.zeros(N)\n",
        "\n",
        "    # ── İç nodlar ─────────────────────────────────────\n",
        "    for i in range(1, N-1):\n",
        "        A_mat[i, i-1] =  kA / dx**2\n",
        "        A_mat[i, i]   = -2 * kA / dx**2\n",
        "        A_mat[i, i+1] =  kA / dx**2\n",
        "        b[i]          =  0.0\n",
        "\n",
        "    # ── Sol sınır (x=0): Konveksiyon ─────────────────────\n",
        "    # h(T_inf - T_0) + kA*(T_1 - T_0)/dx = 0\n",
        "    A_mat[0, 0] = -(h + kA/dx)\n",
        "    A_mat[0, 1] =   kA/dx\n",
        "    b[0]        =  -h * T_inf\n",
        "\n",
        "    # ── Sağ sınır (x=L): Konveksiyon + Radyasyon ────────────\n",
        "    # kA*(T_{N-2} - T_{N-1})/dx + h*(T_inf - T_{N-1})\n",
        "    #   + eps*sigma*(T_rad^4 - T_{N-1}^4) = 0\n",
        "    # Radyasyon linearize: T^4 ≈ T_old^4 + 4*T_old^3*(T - T_old)\n",
        "    Tr      = T_old[-1]\n",
        "    rad_c   = 4 * eps * sigma * Tr**3\n",
        "    rad_rhs = eps * sigma * (T_rad**4 - Tr**4) + rad_c * Tr\n",
        "\n",
        "    A_mat[-1, -2] =  kA/dx\n",
        "    A_mat[-1, -1] = -(kA/dx + h + rad_c)\n",
        "    b[-1]         =  -(h * T_inf + rad_rhs)\n",
        "\n",
        "    T = np.linalg.solve(A_mat, b)\n",
        "\n",
        "    if np.max(np.abs(T - T_old)) < tol:\n",
        "        print(f\"Yakınsadı — iterasyon: {iteration+1}\")\n",
        "        break\n",
        "else:\n",
        "    print(\"Uyarı: yakınsamadı!\")\n",
        "\n",
        "x1 = np.linspace(0, L, N)\n",
        "\n",
        "print(\"\\n   x (m)       T (K)\")\n",
        "print(\"─\" * 28)\n",
        "for xi, Ti in zip(x1, T):\n",
        "    print(f\"   {xi:.4f}      {Ti:.2f}\")\n",
        "\n",
        "#  PROBLEM 2 — 1D, y yönü, 4 Katmanlı Malzeme\n",
        "\n",
        "print(\"\\n\" + \"=\" * 50)\n",
        "print(\"PROBLEM 2 — 4 Katmanlı (A,B,C,D), y yönü\")\n",
        "print(\"=\" * 50)\n",
        "\n",
        "# ─── Malzeme özellikleri ─────\n",
        "k_materials = {\n",
        "    'A': 50.0,   # W/m·K\n",
        "    'B': 30.0,\n",
        "    'C': 15.0,\n",
        "    'D': 5.0,\n",
        "}\n",
        "\n",
        "# Her katman eşit kalınlıkta varsayım\n",
        "L_total   = 0.1          # m   toplam yükseklik\n",
        "n_layers  = 4\n",
        "N_per     = 6            # katman başına nod (iç + sınır)\n",
        "N2        = n_layers * N_per - (n_layers - 1)  # arayüz nodları paylaşılır\n",
        "dy        = L_total / (N2 - 1)\n",
        "\n",
        "# Konveksiyon (y=0 alt, y=L üst)\n",
        "h2        = 100.0\n",
        "T_inf2    = 300.0\n",
        "\n",
        "# Radyasyon (y=0 alt VE y=L üst)\n",
        "eps2      = 0.85\n",
        "T_rad2    = 800.0\n",
        "\n",
        "# ─── Her noda malzeme ata ───────────────────────────────────\n",
        "# Katmanlar: A → alt, D → üst (y arttıkça D'ye geçiyor)\n",
        "layer_names  = ['A', 'B', 'C', 'D']\n",
        "nodes_per_layer = (N2 - 1) // n_layers  # yaklaşık\n",
        "\n",
        "k_node = np.zeros(N2)\n",
        "for i in range(N2):\n",
        "    layer_idx       = min(int(i / ((N2-1) / n_layers)), n_layers - 1)\n",
        "    k_node[i]       = k_materials[layer_names[layer_idx]]\n",
        "\n",
        "# Arayüz nodlarında harmonik ortalama k kullanılır\n",
        "def k_interface(k_left, k_right):\n",
        "    return 2 * k_left * k_right / (k_left + k_right)\n",
        "\n",
        "# ─── Başlangıç tahmini ──────────────────────────────────────\n",
        "T2 = np.linspace(T_inf2, T_rad2, N2)\n",
        "\n",
        "for iteration in range(max_iter):\n",
        "    T2_old = T2.copy()\n",
        "\n",
        "    A2 = np.zeros((N2, N2))\n",
        "    b2 = np.zeros(N2)\n",
        "\n",
        "    # ── İç nodlar ───────────────────────────────────────────\n",
        "    for i in range(1, N2 - 1):\n",
        "        k_w = k_interface(k_node[i-1], k_node[i])    # batı yüzü\n",
        "        k_e = k_interface(k_node[i],   k_node[i+1])  # doğu yüzü\n",
        "\n",
        "        A2[i, i-1] =  k_w / dy**2\n",
        "        A2[i, i]   = -(k_w + k_e) / dy**2\n",
        "        A2[i, i+1] =  k_e / dy**2\n",
        "        b2[i]      =  0.0\n",
        "\n",
        "    # ── Alt sınır (y=0): Konveksiyon + Radyasyon ────────────\n",
        "    Tr0      = T2_old[0]\n",
        "    rad_c0   = 4 * eps2 * sigma * Tr0**3\n",
        "    rad_rhs0 = eps2 * sigma * (T_rad2**4 - Tr0**4) + rad_c0 * Tr0\n",
        "\n",
        "    A2[0, 0] = -(k_node[0]/dy + h2 + rad_c0)\n",
        "    A2[0, 1] =   k_node[0]/dy\n",
        "    b2[0]    =  -(h2 * T_inf2 + rad_rhs0)\n",
        "\n",
        "    # ── Üst sınır (y=L): Konveksiyon + Radyasyon ────────────\n",
        "    Tr_top      = T2_old[-1]\n",
        "    rad_c_top   = 4 * eps2 * sigma * Tr_top**3\n",
        "    rad_rhs_top = eps2 * sigma * (T_rad2**4 - Tr_top**4) + rad_c_top * Tr_top\n",
        "\n",
        "    A2[-1, -2] =  k_node[-1]/dy\n",
        "    A2[-1, -1] = -(k_node[-1]/dy + h2 + rad_c_top)\n",
        "    b2[-1]     =  -(h2 * T_inf2 + rad_rhs_top)\n",
        "\n",
        "    T2 = np.linalg.solve(A2, b2)\n",
        "\n",
        "    if np.max(np.abs(T2 - T2_old)) < tol:\n",
        "        print(f\"Yakınsadı — iterasyon: {iteration+1}\")\n",
        "        break\n",
        "else:\n",
        "    print(\"Uyarı: yakınsamadı!\")\n",
        "\n",
        "y2 = np.linspace(0, L_total, N2)\n",
        "\n",
        "print(\"\\n   y (m)       T (K)      Malzeme\")\n",
        "print(\"─\" * 38)\n",
        "for i, (yi, Ti) in enumerate(zip(y2, T2)):\n",
        "    layer_idx = min(int(i / ((N2-1) / n_layers)), n_layers - 1)\n",
        "    print(f\"   {yi:.4f}      {Ti:.2f}       {layer_names[layer_idx]}\")\n",
        "\n",
        "# ╔══════════════════════════════════════════════════════════╗\n",
        "# ║                      GRAFIKLER                           ║\n",
        "# ╚══════════════════════════════════════════════════════════╝\n",
        "\n",
        "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 6))\n",
        "\n",
        "# Problem 1\n",
        "ax1.plot(x1 * 100, T, 'b-o', markersize=4)\n",
        "ax1.set_xlabel(\"x (cm)\")\n",
        "ax1.set_ylabel(\"Sıcaklık (K)\")\n",
        "ax1.set_title(\"Problem 1 — Malzeme A\\n(Sol/Sağ: Konveksiyon | Sağ'da ayrıca Radyasyon)\")\n",
        "ax1.grid(True)\n",
        "\n",
        "# Problem 2 — katmanları renklendir\n",
        "colors = ['#AED6F1', '#A9DFBF', '#F9E79F', '#F1948A']\n",
        "boundaries = np.linspace(0, L_total * 100, n_layers + 1)\n",
        "for idx, (name, color) in enumerate(zip(layer_names, colors)):\n",
        "    ax2.axhspan(boundaries[idx], boundaries[idx+1],\n",
        "                alpha=0.3, color=color, label=f\"Malzeme {name}\")\n",
        "\n",
        "ax2.plot(T2, y2 * 100, 'r-o', markersize=4)\n",
        "ax2.set_xlabel(\"Sıcaklık (K)\")\n",
        "ax2.set_ylabel(\"y (cm)\")\n",
        "ax2.set_title(\"Problem 2 — 4 Katmanlı (A,B,C,D)\\n(Alt/Üst: Konveksiyon + Radyasyon)\")\n",
        "ax2.legend(loc='right')\n",
        "ax2.grid(True)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ]
    }
  ]
